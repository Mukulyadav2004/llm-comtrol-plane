{
  "version": "{{ version }}",
  "generated_at": "{{ generated_at }}",
  "routes": [
    {% for route in routes if route.enabled %}
    {
      "name": "{{ route.name }}",
      "provider": "{{ route.provider }}",
      "model": "{{ route.model }}",
      "base_url": "{{ route.base_url or '' }}",
      "policy": {
        "max_tokens": {{ route.max_tokens }},
        "temperature": {{ route.temperature }},
        "rate_limit_rpm": {{ route.rate_limit_rpm }},
        "cost_per_1k_tokens": {{ route.cost_per_1k_tokens }}
      },
      "fallback": {{ '"' + route.fallback_route_name + '"' if route.fallback_route_name else 'null' }},
      "guardrail_ids": {{ route.guardrail_ids | tojson }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "guardrails": [
    {% for g in guardrails if g.enabled %}
    {
      "id": "{{ g.id }}",
      "name": "{{ g.name }}",
      "type": "{{ g.guardrail_type }}",
      "apply_on_input": {{ g.apply_on_input | lower }},
      "apply_on_output": {{ g.apply_on_output | lower }},
      "action_on_violation": "{{ g.action_on_violation }}",
      "config": {{ g.config | tojson }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "mcp_servers": [
    {% for s in mcp_servers if s.enabled and s.healthy %}
    {
      "name": "{{ s.name }}",
      "endpoint_url": "{{ s.endpoint_url }}",
      "capabilities": {{ s.capabilities | tojson }},
      "tags": {{ s.tags | tojson }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "semantic_rules": [
    {% for r in semantic_rules if r.enabled %}
    {
      "intent": "{{ r.intent }}",
      "route_name": "{{ r.route_name }}",
      "keyword_hints": {{ r.keyword_hints | tojson }},
      "priority": {{ r.priority }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "observability_configs": [
    {% for o in observability_configs if o.enabled and o.provisioned %}
    {
      "name": "{{ o.name }}",
      "provider": "{{ o.provider }}",
      "project_name": "{{ o.project_name }}",
      "remote_project_id": {{ '"' + o.remote_project_id + '"' if o.remote_project_id else 'null' }},
      "credentials": {{ o.credentials | tojson }},
      "route_names": {{ o.route_names | tojson }},
      "endpoint_url": {{ '"' + o.endpoint_url + '"' if o.endpoint_url else 'null' }},
      "enabled": {{ o.enabled | lower }},
      "provisioned": {{ o.provisioned | lower }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
